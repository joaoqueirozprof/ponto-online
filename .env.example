# ===========================
# Ponto Online - Environment
# ===========================

# Database
DATABASE_URL=postgresql://ponto_admin:PontoSecure2026!@localhost:5433/ponto_online
DB_PASSWORD=PontoSecure2026!

# Redis
REDIS_URL=redis://localhost:6380

# API (NestJS Backend)
API_PORT=4010
API_HOST=0.0.0.0
NODE_ENV=development

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4010/api/v1
API_URL=http://localhost:4010/api/v1

# JWT Authentication
JWT_SECRET=change-this-jwt-secret-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:3010

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Device Connector Agent (roda no escritório)
DEVICE_CONNECTOR_API_URL=http://72.61.129.78:4010/api/v1
DEVICE_CONNECTOR_API_KEY=change-this-api-key
DEVICE_CONNECTOR_SYNC_INTERVAL=300000
DEVICE_CONNECTOR_LOG_LEVEL=info

# Control iD Device (IP local do relógio no escritório)
CONTROL_ID_IP=192.168.1.100
CONTROL_ID_PORT=443
CONTROL_ID_LOGIN=admin
CONTROL_ID_PASSWORD=admin

# Backup
BACKUP_RETENTION_DAYS=30

# Logging
LOG_LEVEL=info
