{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@shared/*": [
        "packages/shared/src/*"
      ],
      "@device-connector/*": [
        "packages/device-connector/src/*"
      ],
      "@calculation-engine/*": [
        "packages/calculation-engine/src/*"
      ]
    }
  },
  "include": [
    "apps/**",
    "packages/**"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
