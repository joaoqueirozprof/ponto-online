// Ponto Online - Multi-tenant SaaS Schema
// v2.0 - Multi-tenant with subscriptions, LGPD compliance, Portaria 671

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SUBSCRIPTION & BILLING
// ============================================================

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique // "Starter", "Professional", "Enterprise"
  description String?

  maxEmployees  Int     @default(20)
  maxBranches   Int     @default(1)
  maxDevices    Int     @default(2)
  maxUsers      Int     @default(3)

  features    Json?    // { "aiAssistant": true, "apiAccess": false, "customReports": true }

  priceMonthly  Int    @default(0) // cents BRL (9900 = R$99,00)
  priceYearly   Int    @default(0) // cents BRL

  isActive    Boolean  @default(true)
  trialDays   Int      @default(14)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id        String   @id @default(cuid())
  companyId String   @unique
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  planId    String
  plan      Plan     @relation(fields: [planId], references: [id])

  status    SubscriptionStatus @default(TRIAL)

  trialEndsAt     DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  // Gateway de pagamento
  externalId        String?   // ID no Asaas/Stripe
  externalCustomerId String?
  paymentMethod     String?   // "pix", "boleto", "credit_card"

  cancelledAt DateTime?
  cancelReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoices    Invoice[]

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

model Invoice {
  id              String   @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amount          Int      // cents BRL
  status          InvoiceStatus @default(PENDING)

  dueDate         DateTime
  paidAt          DateTime?

  externalId      String?  // ID no gateway
  paymentUrl      String?  // URL boleto/PIX

  description     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

// ============================================================
// COMPANY & TENANT
// ============================================================

model Company {
  id    String   @id @default(cuid())
  name  String
  cnpj  String   @unique
  address String?
  phone String?
  email String?

  // Settings
  logoUrl     String?
  timezone    String   @default("America/Sao_Paulo")

  // LGPD
  privacyPolicyAcceptedAt DateTime?
  dpoName     String?   // Encarregado de Dados
  dpoEmail    String?
  dataRetentionMonths Int @default(60) // 5 anos = 60 meses

  // Status
  isActive    Boolean  @default(true)
  blockedAt   DateTime?
  blockReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches     Branch[]
  systemUsers  SystemUser[]
  auditLogs    AuditLog[]
  subscription Subscription?

  @@map("companies")
}

model Branch {
  id String @id @default(cuid())
  companyId String
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String
  code String @unique
  address String?
  phone String?
  timezone String @default("America/Sao_Paulo")
  toleranceMinutes Int @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  systemUsers SystemUser[]
  employees Employee[]
  devices Device[]
  workSchedules WorkSchedule[]
  holidays Holiday[]
  calculationRuns CalculationRun[]
  auditLogs AuditLog[]

  @@index([companyId])
  @@map("branches")
}

// ============================================================
// AUTH & RBAC
// ============================================================

model SystemUser {
  id String @id @default(cuid())
  email String @unique
  passwordHash String
  name String

  // Multi-tenant: user belongs to a company
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  roleId String
  role Role @relation(fields: [roleId], references: [id])

  branchId String?
  branch Branch? @relation(fields: [branchId], references: [id])

  isActive Boolean @default(true)
  lastLogin DateTime?

  // Password reset
  resetToken      String?
  resetTokenExpiry DateTime?

  // LGPD: support access audit
  isSuperAdmin    Boolean @default(false) // Platform owner (João)
  supportAccessEnabled Boolean @default(false)
  supportAccessExpiry  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
  timesheetApprovals Timesheet[] @relation("approver")

  @@index([companyId])
  @@index([roleId])
  @@index([branchId])
  @@map("system_users")
}

model Role {
  id String @id @default(cuid())
  name String @unique
  description String?

  // Whether this role is system-wide or company-specific
  isSystem Boolean @default(false) // true = SUPER_ADMIN only
  companyId String? // null = global role, set = company-specific custom role

  createdAt DateTime @default(now())

  systemUsers SystemUser[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id String @id @default(cuid())
  code String @unique
  description String?

  // Group permissions for UI display
  module String? // "users", "employees", "punches", "timesheets", "reports", "devices", "admin", "billing"

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId String
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// EMPLOYEES
// ============================================================

model Employee {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name String
  cpf String @unique
  pis String?
  registration String?
  email String?
  phone String?
  position String?
  department String?

  scheduleId String?
  schedule WorkSchedule? @relation(fields: [scheduleId], references: [id])

  admissionDate DateTime
  terminationDate DateTime?
  isActive Boolean @default(true)
  deviceUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawPunchEvents RawPunchEvent[]
  normalizedPunches NormalizedPunch[]
  timesheets Timesheet[]
  timeBalances TimeBalance[]
  punchAdjustments PunchAdjustment[]
  calculationIssues CalculationIssue[]
  overtimeAdjustments OvertimeAdjustment[]
  punchReceipts PunchReceipt[]

  @@index([branchId])
  @@index([scheduleId])
  @@map("employees")
}

// ============================================================
// DEVICES
// ============================================================

model Device {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name String
  model String
  serialNumber String @unique
  ipAddress String
  port Int @default(8080)
  login String
  encryptedPassword String

  isActive Boolean @default(true)
  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawPunchEvents RawPunchEvent[]
  deviceSyncLogs DeviceSyncLog[]

  @@index([branchId])
  @@map("devices")
}

model DeviceSyncLog {
  id String @id @default(cuid())
  deviceId String
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  syncType String
  status String
  recordsProcessed Int @default(0)
  errorMessage String?

  startedAt DateTime @default(now())
  finishedAt DateTime?

  @@index([deviceId])
  @@map("device_sync_logs")
}

// ============================================================
// SCHEDULES
// ============================================================

model WorkSchedule {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name String
  type ScheduleType
  weeklyHours Int
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  scheduleEntries ScheduleEntry[]

  @@index([branchId])
  @@map("work_schedules")
}

enum ScheduleType {
  FIXED
  ROTATING
  FLEXIBLE
}

model ScheduleEntry {
  id String @id @default(cuid())
  scheduleId String
  schedule WorkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String
  endTime String
  breakStartTime String?
  breakEndTime String?
  breakMinutes Int @default(0)
  isWorkDay Boolean @default(true)

  timesheetDays TimesheetDay[]

  @@index([scheduleId])
  @@map("schedule_entries")
}

model Holiday {
  id String @id @default(cuid())
  branchId String?
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  date DateTime
  name String
  type HolidayType

  createdAt DateTime @default(now())

  @@index([branchId, date])
  @@map("holidays")
}

enum HolidayType {
  NATIONAL
  STATE
  MUNICIPAL
  COMPANY
}

// ============================================================
// PUNCH RECORDS
// ============================================================

model RawPunchEvent {
  id String @id @default(cuid())
  deviceId String
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  employeeId String?
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  punchTime DateTime
  source String
  rawData Json?

  importedAt DateTime @default(now())
  processedAt DateTime?

  normalizedPunch NormalizedPunch?

  @@index([deviceId])
  @@index([employeeId])
  @@index([punchTime])
  @@map("raw_punch_events")
}

model NormalizedPunch {
  id String @id @default(cuid())
  rawPunchEventId String @unique
  rawPunchEvent RawPunchEvent @relation(fields: [rawPunchEventId], references: [id], onDelete: Cascade)

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  punchTime DateTime
  punchType PunchType
  status PunchStatus @default(NORMAL)

  originalTime DateTime
  adjustedBy String?
  adjustmentReason String?

  createdAt DateTime @default(now())

  punchAdjustments PunchAdjustment[]
  punchReceipt PunchReceipt?

  @@index([employeeId])
  @@index([punchTime])
  @@map("normalized_punches")
}

enum PunchType {
  ENTRY
  EXIT
  BREAK_START
  BREAK_END
}

enum PunchStatus {
  NORMAL
  ADJUSTED
  MANUAL
}

// ============================================================
// PORTARIA 671 - COMPROVANTE DE PONTO
// ============================================================

model PunchReceipt {
  id String @id @default(cuid())

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  normalizedPunchId String @unique
  normalizedPunch NormalizedPunch @relation(fields: [normalizedPunchId], references: [id], onDelete: Cascade)

  // Dados do comprovante (Portaria 671)
  employerName   String  // Razão social
  employerCnpj   String
  employeeName   String
  employeePis    String?
  punchDateTime  DateTime
  punchType      String  // "Entrada", "Saída", etc.

  // Hash para integridade (simula assinatura digital)
  receiptHash    String

  // Delivery
  sentViaEmail   Boolean @default(false)
  sentAt         DateTime?
  pdfPath        String?

  createdAt      DateTime @default(now())

  @@index([employeeId])
  @@map("punch_receipts")
}

// ============================================================
// PORTARIA 671 - AFD (Arquivo Fonte de Dados)
// ============================================================

model AfdExport {
  id String @id @default(cuid())

  companyId    String
  branchId     String?

  startDate    DateTime
  endDate      DateTime

  // File info
  filePath     String
  fileHash     String   // SHA-256 do arquivo
  recordCount  Int

  // Who generated
  generatedBy  String
  generatedAt  DateTime @default(now())

  // Fiscal
  requestedByAuditor Boolean @default(false)
  auditorName        String?

  @@index([companyId])
  @@map("afd_exports")
}

// ============================================================
// TIMESHEETS
// ============================================================

model Timesheet {
  id String @id @default(cuid())
  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month Int
  year Int
  status TimesheetStatus @default(OPEN)

  totalWorkedMinutes Int @default(0)
  totalOvertimeMinutes Int @default(0)
  totalNightMinutes Int @default(0)
  totalAbsenceMinutes Int @default(0)
  totalLateMinutes Int @default(0)
  totalBalanceMinutes Int @default(0)

  calculatedAt DateTime?
  approvedBy String?
  approver SystemUser? @relation("approver", fields: [approvedBy], references: [id])
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timesheetDays TimesheetDay[]

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([status])
  @@map("timesheets")
}

enum TimesheetStatus {
  OPEN
  CALCULATED
  CLOSED
  APPROVED
}

model TimesheetDay {
  id String @id @default(cuid())
  timesheetId String
  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  scheduleEntryId String?
  scheduleEntry ScheduleEntry? @relation(fields: [scheduleEntryId], references: [id])

  date DateTime
  workedMinutes Int @default(0)
  overtimeMinutes Int @default(0)
  nightMinutes Int @default(0)
  lateMinutes Int @default(0)
  absenceMinutes Int @default(0)
  breakMinutes Int @default(0)
  punchCount Int @default(0)
  status DayStatus @default(NORMAL)
  notes String?

  createdAt DateTime @default(now())

  @@index([timesheetId])
  @@map("timesheet_days")
}

enum DayStatus {
  NORMAL
  HOLIDAY
  WEEKEND
  ABSENCE
  INCOMPLETE
}

model TimeBalance {
  id String @id @default(cuid())
  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month Int
  year Int
  previousBalance Int
  currentBalance Int
  adjustments Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@map("time_balances")
}

model PunchAdjustment {
  id String @id @default(cuid())
  normalizedPunchId String
  normalizedPunch NormalizedPunch @relation(fields: [normalizedPunchId], references: [id], onDelete: Cascade)

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  adjustedBy String
  originalTime DateTime
  newTime DateTime
  reason String

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@map("punch_adjustments")
}

model CalculationRun {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  month Int
  year Int
  status CalculationStatus @default(RUNNING)

  employeesProcessed Int @default(0)
  errorsFound Int @default(0)

  startedAt DateTime @default(now())
  finishedAt DateTime?

  calculationIssues CalculationIssue[]

  @@index([branchId])
  @@map("calculation_runs")
}

enum CalculationStatus {
  RUNNING
  COMPLETED
  FAILED
}

model CalculationIssue {
  id String @id @default(cuid())
  calculationRunId String
  calculationRun CalculationRun @relation(fields: [calculationRunId], references: [id], onDelete: Cascade)

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date DateTime?
  issueType IssueType
  description String

  resolved Boolean @default(false)
  resolvedBy String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([calculationRunId])
  @@index([employeeId])
  @@map("calculation_issues")
}

enum IssueType {
  MISSING_PUNCH
  OVERTIME_EXCEEDED
  NO_BREAK
  SCHEDULE_CONFLICT
  OTHER
}

model OvertimeAdjustment {
  id String @id @default(cuid())
  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month Int
  year Int
  field String // 'overtime', 'absence', 'late'
  originalMinutes Int
  adjustedMinutes Int
  reason String
  adjustedBy String @default("RH")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month, year, field])
  @@index([employeeId])
  @@map("overtime_adjustments")
}

// ============================================================
// AUDIT LOG (LGPD Compliant)
// ============================================================

model AuditLog {
  id String @id @default(cuid())
  userId String
  user SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  action String    // "CREATE", "UPDATE", "DELETE", "VIEW", "EXPORT", "SUPPORT_ACCESS"
  entity String
  entityId String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?

  // LGPD: track if this was a support access
  isSupportAccess Boolean @default(false)

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  branchId String?

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([companyId])
  @@map("audit_logs")
}
