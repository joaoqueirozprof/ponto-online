// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id    String   @id @default(cuid())
  name  String
  cnpj  String   @unique
  address String?
  phone String?
  email String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]
  auditLogs AuditLog[]

  @@map("companies")
}

model Branch {
  id String @id @default(cuid())
  companyId String
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String
  code String @unique
  address String?
  phone String?
  timezone String @default("America/Sao_Paulo")
  toleranceMinutes Int @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  systemUsers SystemUser[]
  employees Employee[]
  devices Device[]
  workSchedules WorkSchedule[]
  holidays Holiday[]
  calculationRuns CalculationRun[]
  auditLogs AuditLog[]

  @@index([companyId])
  @@map("branches")
}

model SystemUser {
  id String @id @default(cuid())
  email String @unique
  passwordHash String
  name String
  roleId String
  role Role @relation(fields: [roleId], references: [id])
  branchId String?
  branch Branch? @relation(fields: [branchId], references: [id])

  isActive Boolean @default(true)
  lastLogin DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
  timesheetApprovals Timesheet[] @relation("approver")

  @@index([roleId])
  @@index([branchId])
  @@map("system_users")
}

model Role {
  id String @id @default(cuid())
  name String @unique
  description String?

  createdAt DateTime @default(now())

  systemUsers SystemUser[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id String @id @default(cuid())
  code String @unique
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId String
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Employee {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name String
  cpf String @unique
  pis String?
  registration String?
  email String?
  phone String?
  position String?
  department String?

  scheduleId String?
  schedule WorkSchedule? @relation(fields: [scheduleId], references: [id])

  admissionDate DateTime
  terminationDate DateTime?
  isActive Boolean @default(true)
  deviceUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawPunchEvents RawPunchEvent[]
  normalizedPunches NormalizedPunch[]
  timesheets Timesheet[]
  timeBalances TimeBalance[]
  punchAdjustments PunchAdjustment[]
  calculationIssues CalculationIssue[]
  overtimeAdjustments OvertimeAdjustment[]

  @@index([branchId])
  @@index([scheduleId])
  @@map("employees")
}

model Device {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name String
  model String
  serialNumber String @unique
  ipAddress String
  port Int @default(8080)
  login String
  encryptedPassword String

  isActive Boolean @default(true)
  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rawPunchEvents RawPunchEvent[]
  deviceSyncLogs DeviceSyncLog[]

  @@index([branchId])
  @@map("devices")
}

model DeviceSyncLog {
  id String @id @default(cuid())
  deviceId String
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  syncType String
  status String
  recordsProcessed Int @default(0)
  errorMessage String?

  startedAt DateTime @default(now())
  finishedAt DateTime?

  @@index([deviceId])
  @@map("device_sync_logs")
}

model WorkSchedule {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  name String
  type ScheduleType
  weeklyHours Int
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  scheduleEntries ScheduleEntry[]

  @@index([branchId])
  @@map("work_schedules")
}

enum ScheduleType {
  FIXED
  ROTATING
  FLEXIBLE
}

model ScheduleEntry {
  id String @id @default(cuid())
  scheduleId String
  schedule WorkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String
  endTime String
  breakStartTime String?
  breakEndTime String?
  breakMinutes Int @default(0)
  isWorkDay Boolean @default(true)

  timesheetDays TimesheetDay[]

  @@index([scheduleId])
  @@map("schedule_entries")
}

model Holiday {
  id String @id @default(cuid())
  branchId String?
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  date DateTime
  name String
  type HolidayType

  createdAt DateTime @default(now())

  @@index([branchId, date])
  @@map("holidays")
}

enum HolidayType {
  NATIONAL
  STATE
  MUNICIPAL
  COMPANY
}

model RawPunchEvent {
  id String @id @default(cuid())
  deviceId String
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  employeeId String?
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  punchTime DateTime
  source String
  rawData Json?

  importedAt DateTime @default(now())
  processedAt DateTime?

  normalizedPunch NormalizedPunch?

  @@index([deviceId])
  @@index([employeeId])
  @@index([punchTime])
  @@map("raw_punch_events")
}

model NormalizedPunch {
  id String @id @default(cuid())
  rawPunchEventId String @unique
  rawPunchEvent RawPunchEvent @relation(fields: [rawPunchEventId], references: [id], onDelete: Cascade)

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  punchTime DateTime
  punchType PunchType
  status PunchStatus @default(NORMAL)

  originalTime DateTime
  adjustedBy String?
  adjustmentReason String?

  createdAt DateTime @default(now())

  punchAdjustments PunchAdjustment[]

  @@index([employeeId])
  @@index([punchTime])
  @@map("normalized_punches")
}

enum PunchType {
  ENTRY
  EXIT
  BREAK_START
  BREAK_END
}

enum PunchStatus {
  NORMAL
  ADJUSTED
  MANUAL
}

model Timesheet {
  id String @id @default(cuid())
  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month Int
  year Int
  status TimesheetStatus @default(OPEN)

  totalWorkedMinutes Int @default(0)
  totalOvertimeMinutes Int @default(0)
  totalNightMinutes Int @default(0)
  totalAbsenceMinutes Int @default(0)
  totalLateMinutes Int @default(0)
  totalBalanceMinutes Int @default(0)

  calculatedAt DateTime?
  approvedBy String?
  approver SystemUser? @relation("approver", fields: [approvedBy], references: [id])
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timesheetDays TimesheetDay[]

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([status])
  @@map("timesheets")
}

enum TimesheetStatus {
  OPEN
  CALCULATED
  CLOSED
  APPROVED
}

model TimesheetDay {
  id String @id @default(cuid())
  timesheetId String
  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  scheduleEntryId String?
  scheduleEntry ScheduleEntry? @relation(fields: [scheduleEntryId], references: [id])

  date DateTime
  workedMinutes Int @default(0)
  overtimeMinutes Int @default(0)
  nightMinutes Int @default(0)
  lateMinutes Int @default(0)
  absenceMinutes Int @default(0)
  breakMinutes Int @default(0)
  punchCount Int @default(0)
  status DayStatus @default(NORMAL)
  notes String?

  createdAt DateTime @default(now())

  @@index([timesheetId])
  @@map("timesheet_days")
}

enum DayStatus {
  NORMAL
  HOLIDAY
  WEEKEND
  ABSENCE
  INCOMPLETE
}

model TimeBalance {
  id String @id @default(cuid())
  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month Int
  year Int
  previousBalance Int
  currentBalance Int
  adjustments Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@map("time_balances")
}

model PunchAdjustment {
  id String @id @default(cuid())
  normalizedPunchId String
  normalizedPunch NormalizedPunch @relation(fields: [normalizedPunchId], references: [id], onDelete: Cascade)

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  adjustedBy String
  originalTime DateTime
  newTime DateTime
  reason String

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@map("punch_adjustments")
}

model CalculationRun {
  id String @id @default(cuid())
  branchId String
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  month Int
  year Int
  status CalculationStatus @default(RUNNING)

  employeesProcessed Int @default(0)
  errorsFound Int @default(0)

  startedAt DateTime @default(now())
  finishedAt DateTime?

  calculationIssues CalculationIssue[]

  @@index([branchId])
  @@map("calculation_runs")
}

enum CalculationStatus {
  RUNNING
  COMPLETED
  FAILED
}

model CalculationIssue {
  id String @id @default(cuid())
  calculationRunId String
  calculationRun CalculationRun @relation(fields: [calculationRunId], references: [id], onDelete: Cascade)

  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date DateTime?
  issueType IssueType
  description String

  resolved Boolean @default(false)
  resolvedBy String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([calculationRunId])
  @@index([employeeId])
  @@map("calculation_issues")
}

enum IssueType {
  MISSING_PUNCH
  OVERTIME_EXCEEDED
  NO_BREAK
  SCHEDULE_CONFLICT
  OTHER
}

model OvertimeAdjustment {
  id String @id @default(cuid())
  employeeId String
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month Int
  year Int
  field String // 'overtime', 'absence', 'late'
  originalMinutes Int
  adjustedMinutes Int
  reason String
  adjustedBy String @default("RH")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month, year, field])
  @@index([employeeId])
  @@map("overtime_adjustments")
}

model AuditLog {
  id String @id @default(cuid())
  userId String
  user SystemUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  action String
  entity String
  entityId String
  oldValues Json?
  newValues Json?
  ipAddress String?

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  branchId String?

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
